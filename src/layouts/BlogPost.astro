---
import Layout from './Layout.astro';
import '../styles/blog.css';

const { frontmatter } = Astro.props;

const dateStr = new Date(frontmatter.date).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
});
---

<Layout pageTitle={frontmatter.title}>
    <div class="page-container">
        <div class="post-header">
            <a href={`${import.meta.env.BASE_URL}blog/`} class="back-link">← Blog</a>
            <h1 class="post-title">{frontmatter.title}</h1>
            <div class="post-meta">
                <time datetime={frontmatter.date}>{dateStr}</time>
                {frontmatter.tags && (
                    <div class="post-tags">
                        {frontmatter.tags.map((tag: string) => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                )}
            </div>
            {frontmatter.description && (
                <p class="post-description">{frontmatter.description}</p>
            )}
        </div>

        <article class="post-body">
            <slot />
        </article>

        <div class="post-footer">
            <a href={`${import.meta.env.BASE_URL}blog/`} class="back-link">← Back to all posts</a>
        </div>
    </div>
</Layout>
